# gluetun.env
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard
WIREGUARD_ADDRESSES=10.8.0.2/32
WIREGUARD_PRIVATE_KEY=$(cat ../secrets/client_private.key)
WIREGUARD_PUBLIC_KEY=$(cat ../secrets/server_public.key)
WIREGUARD_ENDPOINT_IP=<SERVER_PUBLIC_IP>
WIREGUARD_ENDPOINT_PORT=51820
WIREGUARD_ALLOWED_IPS=0.0.0.0/0
DOT=off
DNS_KEEP_NAMESERVER=on
DNS_ADDRESS=1.1.1.1